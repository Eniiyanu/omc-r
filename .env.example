# Atlascore backend URL (e.g. https://your-atlascore.azurewebsites.net)
# Leave empty to run the omcr-demo with in-memory mock data instead.
ATLASCORE_API_URL=

# Service-account credentials used by the omcr-demo to authenticate with atlascore.
# Must match a valid user in the atlascore database.
ATLASCORE_SERVICE_EMAIL=admin@mtn.ng
ATLASCORE_SERVICE_PASSWORD=AtlasAdmin2026!
